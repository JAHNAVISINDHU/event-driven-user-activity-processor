# Copy this file to .env and adjust values as needed.
# docker-compose.yml reads these automatically; they are also used
# directly by producer.py and the test suite when run outside Docker.

# --- RabbitMQ ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
QUEUE_NAME=user_activity_queue
DLX_EXCHANGE=dlx_exchange
DLQ_NAME=user_activity_dlq
DLQ_ROUTING_KEY=dlq

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=activity_db
POSTGRES_USER=activity_user
POSTGRES_PASSWORD=activity_pass

# --- App ---
APP_PORT=8000
CONSUMER_RECONNECT_DELAY_SECONDS=5
